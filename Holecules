<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Reading Molecules \u2014 Learn Anything, One Piece at a Time</title>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,600;0,9..144,700;1,9..144,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />
<style>
  /* \u2500\u2500 Tokens \u2500\u2500 */
  :root {
    --bg:        #f5f2ec;
    --surface:   #fffdf8;
    --border:    #e3ded4;
    --text:      #1a1714;
    --muted:     #7a7268;
    --accent:    #c45c2e;
    --accent2:   #3a6b5c;
    --accent3:   #4a6fa5;
    --atom-bg:   #fef6ee;
    --atom-bd:   #f0d8c4;
    --mol-bg:    #eef5f1;
    --mol-bd:    #c6ddd5;
    --comp-bg:   #edf1f8;
    --comp-bd:   #c4d2e8;
    --shadow:    0 2px 18px rgba(0,0,0,.07);
    --shadow-lg: 0 8px 40px rgba(0,0,0,.11);
    --radius:    14px;
    --transition: .25s cubic-bezier(.4,0,.2,1);
  }
  [data-theme="dark"] {
    --bg:       #141210;
    --surface:  #1e1b18;
    --border:   #2e2a24;
    --text:     #f0ece4;
    --muted:    #8a8278;
    --accent:   #e07348;
    --accent2:  #52a087;
    --accent3:  #7099cc;
    --atom-bg:  #221a12;
    --atom-bd:  #3d2a18;
    --mol-bg:   #121e19;
    --mol-bd:   #1e3d30;
    --comp-bg:  #111826;
    --comp-bd:  #1c2f48;
    --shadow:   0 2px 18px rgba(0,0,0,.3);
    --shadow-lg:0 8px 40px rgba(0,0,0,.4);
  }

  /* \u2500\u2500 Reset \u2500\u2500 */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }
  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--bg);
    color: var(--text);
    line-height: 1.65;
    transition: background var(--transition), color var(--transition);
    overflow-x: hidden;
  }
  img { display: block; max-width: 100%; }
  a { color: inherit; text-decoration: none; }

  /* \u2500\u2500 Nav \u2500\u2500 */
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    display: flex; align-items: center; justify-content: space-between;
    padding: 0 clamp(1.5rem, 5vw, 3rem);
    height: 64px;
    background: color-mix(in srgb, var(--bg) 85%, transparent);
    backdrop-filter: blur(14px);
    border-bottom: 1px solid var(--border);
    transition: background var(--transition), border-color var(--transition);
  }
  .nav-logo {
    font-family: 'Fraunces', serif;
    font-size: 1.25rem;
    font-weight: 700;
    letter-spacing: -.02em;
    color: var(--text);
  }
  .nav-logo span { color: var(--accent); }
  .nav-links {
    display: flex; align-items: center; gap: 2rem;
    list-style: none;
  }
  .nav-links a {
    font-size: .875rem; font-weight: 500;
    color: var(--muted);
    transition: color var(--transition);
  }
  .nav-links a:hover { color: var(--text); }
  .nav-right { display: flex; align-items: center; gap: 1rem; }

  /* Dark mode toggle */
  .toggle-btn {
    display: flex; align-items: center; justify-content: center;
    width: 40px; height: 40px; border-radius: 50%;
    border: 1.5px solid var(--border);
    background: var(--surface);
    cursor: pointer;
    transition: all var(--transition);
    font-size: 1.1rem;
  }
  .toggle-btn:hover { border-color: var(--accent); transform: scale(1.08); }

  /* hamburger */
  .hamburger {
    display: none; flex-direction: column; gap: 5px;
    cursor: pointer; border: none; background: transparent; padding: 4px;
  }
  .hamburger span {
    display: block; width: 22px; height: 2px;
    background: var(--text); border-radius: 2px;
    transition: all var(--transition);
  }
  @media (max-width: 700px) {
    .hamburger { display: flex; }
    .nav-links {
      position: fixed; inset: 64px 0 0 0;
      background: var(--surface);
      flex-direction: column; justify-content: flex-start;
      padding: 2rem; gap: 1.5rem;
      transform: translateX(100%);
      transition: transform var(--transition);
      border-left: 1px solid var(--border);
    }
    .nav-links.open { transform: translateX(0); }
    .nav-links a { font-size: 1.1rem; color: var(--text); }
  }

  /* \u2500\u2500 Hero \u2500\u2500 */
  .hero {
    min-height: 100vh;
    display: flex; align-items: center; justify-content: center;
    flex-direction: column; text-align: center;
    padding: 7rem clamp(1.5rem, 6vw, 4rem) 4rem;
    position: relative; overflow: hidden;
  }
  .hero::before {
    content: '';
    position: absolute; inset: 0;
    background:
      radial-gradient(ellipse 70% 55% at 20% 30%, color-mix(in srgb, var(--accent) 12%, transparent), transparent),
      radial-gradient(ellipse 60% 50% at 80% 70%, color-mix(in srgb, var(--accent2) 10%, transparent), transparent);
    pointer-events: none;
    transition: background var(--transition);
  }
  /* Floating blobs */
  .hero-blob {
    position: absolute; border-radius: 50%; filter: blur(60px); opacity: .18;
    pointer-events: none; animation: float 8s ease-in-out infinite;
  }
  .hero-blob-1 { width: 320px; height: 320px; background: var(--accent); top: 10%; left: -5%; animation-delay: 0s; }
  .hero-blob-2 { width: 240px; height: 240px; background: var(--accent2); bottom: 15%; right: 0; animation-delay: -3s; }
  .hero-blob-3 { width: 180px; height: 180px; background: var(--accent3); top: 55%; left: 55%; animation-delay: -5s; }
  @keyframes float {
    0%, 100% { transform: translateY(0) scale(1); }
    50%       { transform: translateY(-30px) scale(1.05); }
  }

  .hero-eyebrow {
    display: inline-flex; align-items: center; gap: .5rem;
    font-size: .8rem; font-weight: 500; letter-spacing: .1em; text-transform: uppercase;
    color: var(--accent); background: color-mix(in srgb, var(--accent) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--accent) 25%, transparent);
    padding: .35rem 1rem; border-radius: 99px;
    margin-bottom: 1.5rem;
    opacity: 0; animation: fadeUp .7s .2s forwards;
  }
  .hero h1 {
    font-family: 'Fraunces', serif;
    font-size: clamp(3rem, 8vw, 6.5rem);
    font-weight: 700; line-height: 1.05; letter-spacing: -.04em;
    max-width: 14ch;
    opacity: 0; animation: fadeUp .7s .35s forwards;
  }
  .hero h1 em { font-style: italic; color: var(--accent); }
  .hero p {
    margin-top: 1.5rem;
    font-size: clamp(1rem, 2.5vw, 1.2rem);
    color: var(--muted); max-width: 46ch;
    opacity: 0; animation: fadeUp .7s .5s forwards;
  }
  .hero-actions {
    margin-top: 2.5rem;
    display: flex; gap: 1rem; flex-wrap: wrap; justify-content: center;
    opacity: 0; animation: fadeUp .7s .65s forwards;
  }
  .btn {
    display: inline-flex; align-items: center; gap: .5rem;
    padding: .8rem 1.75rem; border-radius: 99px;
    font-size: .95rem; font-weight: 500; cursor: pointer;
    transition: all var(--transition); border: none;
  }
  .btn-primary {
    background: var(--accent); color: #fff;
    box-shadow: 0 4px 20px color-mix(in srgb, var(--accent) 35%, transparent);
  }
  .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 8px 28px color-mix(in srgb, var(--accent) 45%, transparent); }
  .btn-outline {
    background: transparent; color: var(--text);
    border: 1.5px solid var(--border);
  }
  .btn-outline:hover { border-color: var(--text); transform: translateY(-2px); }

  .hero-stats {
    margin-top: 4rem;
    display: flex; gap: clamp(2rem, 6vw, 5rem); flex-wrap: wrap; justify-content: center;
    opacity: 0; animation: fadeUp .7s .8s forwards;
  }
  .stat { text-align: center; }
  .stat-num {
    font-family: 'Fraunces', serif;
    font-size: 2.5rem; font-weight: 700; color: var(--text);
    line-height: 1;
  }
  .stat-label { font-size: .8rem; color: var(--muted); margin-top: .25rem; letter-spacing: .05em; text-transform: uppercase; }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* \u2500\u2500 Section Shell \u2500\u2500 */
  section { padding: 6rem clamp(1.5rem, 6vw, 4rem); }
  .section-header { margin-bottom: 3rem; }
  .section-label {
    display: inline-flex; align-items: center; gap: .5rem;
    font-size: .75rem; font-weight: 600; letter-spacing: .12em; text-transform: uppercase;
    color: var(--muted); margin-bottom: .75rem;
  }
  .section-label::before {
    content: ''; display: block; width: 20px; height: 2px;
    background: currentColor; border-radius: 2px;
  }
  .section-title {
    font-family: 'Fraunces', serif;
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    font-weight: 600; letter-spacing: -.03em; line-height: 1.15;
  }
  .section-sub { margin-top: .6rem; color: var(--muted); font-size: 1rem; max-width: 52ch; }

  /* \u2500\u2500 Atoms \u2500\u2500 */
  #atoms { background: var(--atom-bg); transition: background var(--transition); }
  .atoms-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 1rem;
  }
  .atom-card {
    background: var(--surface);
    border: 1px solid var(--atom-bd);
    border-radius: var(--radius);
    padding: 1.4rem 1.5rem;
    cursor: pointer;
    transition: all var(--transition);
    position: relative; overflow: hidden;
    opacity: 0;
    animation: fadeUp .5s forwards;
  }
  .atom-card:nth-child(1) { animation-delay: .05s; }
  .atom-card:nth-child(2) { animation-delay: .1s; }
  .atom-card:nth-child(3) { animation-delay: .15s; }
  .atom-card:nth-child(4) { animation-delay: .2s; }
  .atom-card:nth-child(5) { animation-delay: .25s; }
  .atom-card:nth-child(6) { animation-delay: .3s; }
  .atom-card:nth-child(7) { animation-delay: .35s; }
  .atom-card:nth-child(8) { animation-delay: .4s; }

  .atom-card::after {
    content: ''; position: absolute; inset: 0;
    background: linear-gradient(135deg, color-mix(in srgb, var(--accent) 5%, transparent), transparent);
    opacity: 0; transition: opacity var(--transition);
  }
  .atom-card:hover { transform: translateY(-4px); box-shadow: var(--shadow-lg); border-color: var(--accent); }
  .atom-card:hover::after { opacity: 1; }

  .atom-icon {
    font-size: 1.6rem; margin-bottom: .75rem;
    transition: transform var(--transition);
  }
  .atom-card:hover .atom-icon { transform: scale(1.15) rotate(-5deg); }
  .atom-card h3 { font-size: .95rem; font-weight: 600; margin-bottom: .35rem; }
  .atom-card p { font-size: .8rem; color: var(--muted); line-height: 1.5; }
  .atom-time {
    display: inline-flex; align-items: center; gap: .3rem;
    font-size: .7rem; color: var(--accent); font-weight: 500;
    margin-top: .75rem;
  }

  /* \u2500\u2500 Molecules \u2500\u2500 */
  .molecules-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.25rem;
  }
  .mol-card {
    background: var(--mol-bg);
    border: 1px solid var(--mol-bd);
    border-radius: var(--radius);
    padding: 2rem;
    cursor: pointer;
    transition: all var(--transition);
    display: flex; flex-direction: column; gap: .75rem;
    opacity: 0; animation: fadeUp .5s forwards;
  }
  .mol-card:nth-child(1) { animation-delay: .05s; }
  .mol-card:nth-child(2) { animation-delay: .15s; }
  .mol-card:nth-child(3) { animation-delay: .25s; }
  .mol-card:hover { transform: translateY(-5px); box-shadow: var(--shadow-lg); border-color: var(--accent2); }

  .mol-tag {
    display: inline-flex; align-items: center; gap: .3rem;
    font-size: .7rem; font-weight: 600; letter-spacing: .08em; text-transform: uppercase;
    color: var(--accent2); padding: .2rem .65rem;
    background: color-mix(in srgb, var(--accent2) 12%, transparent);
    border-radius: 99px;
    align-self: flex-start;
  }
  .mol-card h3 {
    font-family: 'Fraunces', serif;
    font-size: 1.25rem; font-weight: 600; line-height: 1.25;
  }
  .mol-card p { font-size: .875rem; color: var(--muted); }
  .mol-atoms {
    display: flex; flex-wrap: wrap; gap: .4rem; margin-top: .25rem;
  }
  .mol-atom-chip {
    font-size: .7rem; padding: .2rem .55rem;
    background: var(--surface); border: 1px solid var(--border);
    border-radius: 99px; color: var(--muted);
  }
  .mol-footer {
    display: flex; justify-content: space-between; align-items: center;
    margin-top: auto; padding-top: .75rem;
    border-top: 1px solid var(--mol-bd);
    font-size: .8rem; color: var(--muted);
  }
  .mol-arrow {
    width: 30px; height: 30px; border-radius: 50%;
    background: var(--accent2); color: #fff;
    display: flex; align-items: center; justify-content: center;
    font-size: .9rem; transition: transform var(--transition);
  }
  .mol-card:hover .mol-arrow { transform: translateX(4px); }

  /* \u2500\u2500 Compounds \u2500\u2500 */
  #compounds { background: var(--comp-bg); transition: background var(--transition); }
  .compounds-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.5rem;
  }
  .comp-card {
    background: var(--surface);
    border: 1px solid var(--comp-bd);
    border-radius: var(--radius);
    overflow: hidden;
    cursor: pointer;
    transition: all var(--transition);
    opacity: 0; animation: fadeUp .5s forwards;
    display: flex; flex-direction: column;
  }
  .comp-card:nth-child(1) { animation-delay: .05s; }
  .comp-card:nth-child(2) { animation-delay: .15s; }
  .comp-card:nth-child(3) { animation-delay: .25s; }
  .comp-card:hover { transform: translateY(-6px); box-shadow: var(--shadow-lg); border-color: var(--accent3); }

  .comp-banner {
    height: 140px;
    display: flex; align-items: center; justify-content: center;
    font-size: 3rem;
    position: relative; overflow: hidden;
  }
  .comp-banner::before {
    content: ''; position: absolute; inset: 0;
    background: inherit; filter: brightness(.8);
  }
  .comp-banner span { position: relative; z-index: 1; }
  .comp-body { padding: 1.5rem; flex: 1; display: flex; flex-direction: column; gap: .5rem; }
  .comp-badge {
    display: inline-flex; align-items: center; gap: .3rem;
    font-size: .7rem; font-weight: 600; letter-spacing: .08em; text-transform: uppercase;
    color: var(--accent3); align-self: flex-start;
  }
  .comp-card h3 {
    font-family: 'Fraunces', serif;
    font-size: 1.3rem; font-weight: 600; line-height: 1.2;
  }
  .comp-card p { font-size: .85rem; color: var(--muted); flex: 1; }
  .comp-meta {
    display: flex; gap: 1rem;
    font-size: .75rem; color: var(--muted);
    margin-top: .5rem; padding-top: .75rem;
    border-top: 1px solid var(--border);
  }
  .comp-meta span { display: flex; align-items: center; gap: .3rem; }

  /* \u2500\u2500 Progress \u2500\u2500 */
  .progress-section { max-width: 760px; margin: 0 auto; }
  .progress-header {
    display: flex; justify-content: space-between; align-items: center;
    margin-bottom: .6rem;
  }
  .progress-title { font-weight: 500; font-size: .9rem; }
  .progress-pct { font-size: .8rem; color: var(--muted); }
  .progress-track {
    height: 8px; background: var(--border); border-radius: 99px; overflow: hidden;
    margin-bottom: 2rem;
  }
  .progress-fill {
    height: 100%; border-radius: 99px;
    transition: width 1.2s cubic-bezier(.4,0,.2,1);
  }
  .progress-fill.orange { background: linear-gradient(90deg, var(--accent), color-mix(in srgb, var(--accent) 60%, #f5c));}
  .progress-fill.green  { background: linear-gradient(90deg, var(--accent2), color-mix(in srgb, var(--accent2) 60%, #8fc));}
  .progress-fill.blue   { background: linear-gradient(90deg, var(--accent3), color-mix(in srgb, var(--accent3) 60%, #a8f));}

  .progress-summary {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; margin-top: 2.5rem;
  }
  .ps-card {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: var(--radius); padding: 1.25rem; text-align: center;
    transition: all var(--transition);
  }
  .ps-card:hover { box-shadow: var(--shadow); transform: translateY(-2px); }
  .ps-num {
    font-family: 'Fraunces', serif; font-size: 2rem; font-weight: 700;
    color: var(--accent);
  }
  .ps-card:nth-child(2) .ps-num { color: var(--accent2); }
  .ps-card:nth-child(3) .ps-num { color: var(--accent3); }
  .ps-label { font-size: .75rem; color: var(--muted); margin-top: .2rem; }

  /* \u2500\u2500 Footer \u2500\u2500 */
  footer {
    background: var(--surface);
    border-top: 1px solid var(--border);
    padding: 3rem clamp(1.5rem, 6vw, 4rem);
    transition: background var(--transition), border-color var(--transition);
  }
  .footer-inner {
    max-width: 1100px; margin: 0 auto;
    display: grid; grid-template-columns: 1fr auto; gap: 2rem;
    align-items: start;
  }
  .footer-brand .nav-logo { font-size: 1.4rem; margin-bottom: .5rem; }
  .footer-brand p { font-size: .85rem; color: var(--muted); max-width: 32ch; }
  .footer-links { display: flex; gap: 3rem; flex-wrap: wrap; }
  .footer-col h4 { font-size: .8rem; font-weight: 600; letter-spacing: .08em; text-transform: uppercase; color: var(--muted); margin-bottom: .75rem; }
  .footer-col ul { list-style: none; display: flex; flex-direction: column; gap: .5rem; }
  .footer-col a { font-size: .85rem; color: var(--muted); transition: color var(--transition); }
  .footer-col a:hover { color: var(--text); }
  .footer-bottom {
    max-width: 1100px; margin: 2rem auto 0;
    padding-top: 1.5rem; border-top: 1px solid var(--border);
    display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem;
    font-size: .8rem; color: var(--muted);
  }
  @media (max-width: 640px) {
    .footer-inner { grid-template-columns: 1fr; }
    .footer-links { gap: 2rem; }
    .footer-bottom { flex-direction: column; align-items: flex-start; }
    .progress-summary { grid-template-columns: 1fr; }
  }

  /* \u2500\u2500 Modal \u2500\u2500 */
  .modal-overlay {
    display: none; position: fixed; inset: 0; z-index: 200;
    background: rgba(0,0,0,.55); backdrop-filter: blur(6px);
    align-items: center; justify-content: center; padding: 1.5rem;
  }
  .modal-overlay.open { display: flex; animation: fadeIn .2s; }
  @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
  .modal {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 20px; padding: 2.5rem;
    max-width: 520px; width: 100%;
    box-shadow: var(--shadow-lg);
    position: relative;
    animation: slideUp .3s cubic-bezier(.34,1.56,.64,1);
  }
  @keyframes slideUp { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } }
  .modal-close {
    position: absolute; top: 1.25rem; right: 1.25rem;
    width: 32px; height: 32px; border-radius: 50%;
    border: 1.5px solid var(--border); background: transparent;
    font-size: 1rem; cursor: pointer; color: var(--muted);
    display: flex; align-items: center; justify-content: center;
    transition: all var(--transition);
  }
  .modal-close:hover { background: var(--border); color: var(--text); }
  .modal-icon { font-size: 2.5rem; margin-bottom: 1rem; }
  .modal h2 { font-family: 'Fraunces', serif; font-size: 1.5rem; font-weight: 600; margin-bottom: .75rem; }
  .modal p { font-size: .9rem; color: var(--muted); line-height: 1.7; }
  .modal-tags { display: flex; flex-wrap: wrap; gap: .4rem; margin-top: 1.25rem; }
  .modal-tag {
    font-size: .7rem; padding: .25rem .65rem;
    background: var(--bg); border: 1px solid var(--border);
    border-radius: 99px; color: var(--muted);
  }
  .modal-footer { margin-top: 1.75rem; display: flex; gap: .75rem; flex-wrap: wrap; }

  /* \u2500\u2500 Divider \u2500\u2500 */
  .divider {
    max-width: 1100px; margin: 0 auto;
    border: none; border-top: 1px solid var(--border);
  }

  /* scroll-reveal helper */
  .reveal { opacity: 0; transform: translateY(28px); transition: opacity .6s, transform .6s; }
  .reveal.visible { opacity: 1; transform: none; }
</style>
</head>
<body>

<!-- \u2500\u2500 Nav \u2500\u2500 -->
<nav>
  <a class="nav-logo" href="#"><span>\u2b21</span> Reading Molecules</a>
  <ul class="nav-links" id="navLinks">
    <li><a href="#atoms">Atoms</a></li>
    <li><a href="#molecules">Molecules</a></li>
    <li><a href="#compounds">Compounds</a></li>
    <li><a href="#progress">Progress</a></li>
  </ul>
  <div class="nav-right">
    <button class="toggle-btn" id="themeToggle" title="Toggle dark mode">\ud83c\udf19</button>
    <button class="hamburger" id="hamburger" aria-label="Menu">
      <span></span><span></span><span></span>
    </button>
